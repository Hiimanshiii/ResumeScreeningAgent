@page
@model ResumeScreeningAgent.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="dashboard-wrapper py-4">
    <!-- Page Header -->
    <div class="d-flex align-items-center justify-content-between mb-4 pb-2">
        <div>
            <h1 class="fw-bold text-dark mb-1">Resume Screening Dashboard</h1>
            <p class="text-muted mb-0">AI-powered candidate screening and ranking</p>
        </div>
    </div>

    <div id="errorAlert" class="alert alert-danger d-none mb-4" role="alert"></div>

    <div class="position-relative">
        <!-- Loading Overlay -->
        <div id="loadingOverlay" class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center bg-white bg-opacity-75" style="z-index:10;">
            <div class="text-center">
                <div class="spinner-border text-primary" role="status" style="width:2.5rem;height:2.5rem;"></div>
                <div class="mt-2 text-secondary fw-semibold">Loading dashboard...</div>
            </div>
        </div>

        <!-- Metric Cards Grid -->
        <div class="row g-4" id="statsGrid">
            <!-- Total Resumes -->
            <div class="col-12 col-md-6">
                <div class="card shadow-sm stat-card card-total-resumes h-100">
                    <div class="card-body d-flex align-items-center justify-content-between p-4">
                        <div>
                            <h6 class="metric-title mb-2">Total Resumes</h6>
                            <div id="totalResumes" class="metric-value">—</div>
                        </div>
                        <div class="stat-icon-wrapper icon-total-resumes">
                            <i class="bi bi-file-earmark-person"></i>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Top Candidate -->
            <div class="col-12 col-md-6">
                <div class="card shadow-sm stat-card card-top-candidate h-100">
                    <div class="card-body d-flex align-items-center justify-content-between p-4">
                        <div class="overflow-hidden me-3">
                            <h6 class="metric-title mb-2">Top Candidate</h6>
                            <div id="topCandidate" class="metric-value-text text-truncate">—</div>
                        </div>
                        <div class="stat-icon-wrapper icon-top-candidate flex-shrink-0">
                            <i class="bi bi-award"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions Section -->
    <div class="mt-5">
        <h5 class="fw-bold text-dark mb-3">Quick Actions</h5>
        <div class="card shadow-sm quick-actions-card p-4">
            <div class="row g-4">
                <div class="col-12 col-sm-6 col-lg-3">
                    <a asp-page="/UploadResumes" class="btn btn-quick-action w-100">
                        <i class="bi bi-cloud-upload"></i> Upload Resumes
                    </a>
                </div>
                <div class="col-12 col-sm-6 col-lg-3">
                    <a asp-page="/JobDescription" class="btn btn-quick-action w-100">
                        <i class="bi bi-file-earmark-text"></i> Add Job Description
                    </a>
                </div>
                <div class="col-12 col-sm-6 col-lg-3">
                    <a asp-page="/CandidateMatching" class="btn btn-quick-action w-100">
                        <i class="bi bi-people"></i> Match Candidates
                    </a>
                </div>
                <div class="col-12 col-sm-6 col-lg-3">
                    <a asp-page="/Reports" class="btn btn-quick-action w-100">
                        <i class="bi bi-bar-chart-line"></i> Generate Report
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        const overlay = document.getElementById('loadingOverlay');
        const errorAlert = document.getElementById('errorAlert');

        function showLoading() { overlay.classList.remove('d-none'); }
        function hideLoading() { overlay.classList.add('d-none'); }

        function showError(message) {
            errorAlert.textContent = message;
            errorAlert.classList.remove('d-none');
        }

        function populate(data) {
            const totalResumesEl = document.getElementById('totalResumes');
            if (totalResumesEl) {
                totalResumesEl.textContent = data.totalResumes ?? '0';
            }
            const topCandidateEl = document.getElementById('topCandidate');
            if (topCandidateEl) {
                topCandidateEl.textContent = data.topCandidate ?? '—';
            }
        }

        async function loadDashboard() {
            showLoading();
            errorAlert.classList.add('d-none');

            try {
                const res = await fetch('/dashboard', { method: 'GET', headers: { 'Accept': 'application/json' } });
                if (!res.ok) throw new Error('Server returned ' + res.status);
                const json = await res.json();
                populate(json);
            } catch (err) {
                showError('Unable to load dashboard. ' + (err.message || ''));
            } finally {
                hideLoading();
            }
        }

        document.addEventListener('DOMContentLoaded', loadDashboard);
    })();
</script>
